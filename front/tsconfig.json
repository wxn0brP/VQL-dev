{
    "compilerOptions": {
        "module": "esnext",
        "target": "es2024",
        "moduleResolution": "bundler",
        "paths": {
            "#*": [
                "./src/*"
            ],
        },
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "inlineSourceMap": true,
        "strict": false,
        "rootDir": "./src",
        "types": [
            "esbuild-style-plugin"
        ]
    },
    "include": [
        "./src"
    ],
    "exclude": [
        "node_modules"
    ]
}
